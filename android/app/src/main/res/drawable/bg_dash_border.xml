<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Warna latar belakang dalam kotak (putih/transparan) -->
    <solid android:color="#FFFFFF" />

    <!-- Pengaturan Border Putus-putus -->
    <!-- dashWidth: panjang garisnya -->
    <!-- dashGap: jarak antar garis -->
    <stroke
        android:width="2dp"
        android:color="#D1D5DB"
        android:dashWidth="8dp"
        android:dashGap="8dp" />

    <!-- Lengkungan sudut kotak agar senada dengan desain -->
    <corners android:radius="20dp" />

</shape>