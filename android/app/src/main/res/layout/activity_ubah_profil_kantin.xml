<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="25dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/chevronleft" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ubah Data Kantin"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perbarui detail warung &amp; profilmu"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/containerAction"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp"
            android:paddingTop="10dp">

            <!-- FOTO KANTIN (CANTEEN - image) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    app:cardCornerRadius="55dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/ivCanteenLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/avatar" />
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/btnEditCanteenLogo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle_orange_solid"
                    android:padding="8dp"
                    android:src="@drawable/camera" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="Ketuk untuk ganti logo kantin"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <!-- SECTION: DETAIL KANTIN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="IDENTITAS KANTIN"
                android:textColor="#F97316"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCanteenName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/home"
                android:drawablePadding="12dp"
                android:hint="Nama Kantin"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/etCanteenLocation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/mappin"
                android:drawablePadding="12dp"
                android:hint="Lokasi Gedung / Alamat"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/etCanteenDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top"
                android:hint="Deskripsi singkat kantin..."
                android:padding="16dp" />

            <!-- Ongkir & Jam Operasional -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONGKIR (RP)"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etDeliveryFee"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="2000"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.9"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUKA"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etOpenTime"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input_field"
                        android:focusable="false"
                        android:hint="08:00"
                        android:gravity="center"
                        android:textSize="14sp" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.9"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TUTUP"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etCloseTime"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input_field"
                        android:focusable="false"
                        android:hint="17:00"
                        android:gravity="center"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="24dp" android:background="#F3F4F6"/>

            <!-- SECTION: PROFIL ADMIN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROFIL PEMILIK"
                android:textColor="#F97316"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivAdminPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/avatar" />
                    </androidx.cardview.widget.CardView>
                    <ImageView
                        android:id="@+id/btnEditAdminPhoto"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_circle_orange_solid"
                        android:padding="4dp"
                        android:src="@drawable/camera" />
                </FrameLayout>

                <EditText
                    android:id="@+id/etAdminName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Nama Lengkap Admin"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Email (Read-Only) -->
            <EditText
                android:id="@+id/etAdminEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/mail"
                android:drawablePadding="12dp"
                android:enabled="false"
                android:hint="email@admin.com"
                android:paddingHorizontal="16dp"
                android:textColor="#9CA3AF" />

            <EditText
                android:id="@+id/etAdminPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@drawable/phone"
                android:drawablePadding="12dp"
                android:hint="No. Telepon Aktif"
                android:inputType="phone"
                android:paddingHorizontal="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Save Button Container -->
    <LinearLayout
        android:id="@+id/containerAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="12dp"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSubmitAll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_orange_solid"
            android:text="Simpan Perubahan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>