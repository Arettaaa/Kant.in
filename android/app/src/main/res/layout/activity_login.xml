<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <!-- ===== HEADER: LOGO + TAGLINE ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Kotak logo oranye -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F97316"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🍴"
                    android:textSize="32sp"
                    android:gravity="center" />
            </androidx.cardview.widget.CardView>

            <!-- Nama app: Kant.in -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kant"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=".in"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#F97316" />
            </LinearLayout>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solusi untuk pesan\nantar makanan di area kampus."
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ===== FORM CARD ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Label Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alamat Email"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Input Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="#F3F4F6"
                    android:gravity="center_vertical"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp">

                    <!-- Gunakan shape rounded di background LinearLayout ini -->
                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:text="✉"
                        android:textSize="16sp"
                        android:textColor="#9CA3AF"
                        android:gravity="center" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="10dp"
                        android:background="@null"
                        android:hint="email@id"
                        android:hintTextColor="#9CA3AF"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Label Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kata Sandi"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />

                <!-- Input Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="#F3F4F6"
                    android:gravity="center_vertical"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:text="🔒"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:gravity="center" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="10dp"
                        android:background="@null"
                        android:hint="••••••••"
                        android:hintTextColor="#9CA3AF"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <TextView
                        android:id="@+id/tvTogglePassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁"
                        android:textSize="16sp"
                        android:textColor="#9CA3AF"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Lupa Kata Sandi -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Lupa kata sandi?"
                    android:textColor="#F97316"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== TOMBOL MASUK ===== -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="#F97316"
            android:text="Masuk ke Kant.in  ›"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- ===== LINK DAFTAR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? "
                android:textSize="14sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar di sini"
                android:textSize="14sp"
                android:textColor="#F97316"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== LINK PEMILIK KANTIN ===== -->
        <TextView
            android:id="@+id/tvKantinOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="40dp"
            android:text="Masuk sebagai Pemilik Kantin"
            android:textSize="13sp"
            android:textColor="#9CA3AF"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>