<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/layoutHeaderDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/admin_tab_background_parent"
            android:src="@drawable/ic_back"
            app:tint="#111827" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Pesanan"
                android:textColor="#111827"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold" />
            <TextView
                android:id="@+id/tvDetailOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#ORD-089"
                android:textColor="#F97316"
                android:textSize="14sp"
                android:fontFamily="@font/inter_bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderDetail"
        app:layout_constraintBottom_toTopOf="@id/layoutFooterButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/ivCustomerAvatar"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/bg_badge_orange_light" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivCustomerAvatar"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alex Johnson"
                                android:textColor="#111827"
                                android:textSize="17sp"
                                android:fontFamily="@font/inter_bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+62 812-3456-7890"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/inter_regular" />
                        </LinearLayout>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginVertical="16dp"/>

                    <include
                        layout="@layout/row_info_detail"
                        android:id="@+id/rowMetode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Menu Dipesan" android:fontFamily="@font/inter_bold" android:textColor="#111827"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="2 ITEM" android:textColor="#F97316" android:textSize="10sp" android:background="@drawable/admin_badge_orange_light" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:fontFamily="@font/inter_bold"/>
                    </RelativeLayout>

                    <include
                        layout="@layout/item_menu_detail_with_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />

                    <include
                        layout="@layout/item_menu_detail_with_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ringkasan Pembayaran" android:fontFamily="@font/inter_bold" android:textColor="#111827"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Subtotal" android:textColor="#6B7280" android:fontFamily="@font/inter_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Rp 68.000" android:textColor="#111827" android:fontFamily="@font/inter_bold"/>
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Biaya Ongkir" android:textColor="#6B7280" android:fontFamily="@font/inter_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Rp 5.000" android:textColor="#111827" android:fontFamily="@font/inter_bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginVertical="12dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Pembayaran" android:fontFamily="@font/inter_bold" android:textColor="#111827" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Rp 73.000" android:textColor="#F97316" android:textSize="20sp" android:fontFamily="@font/inter_extrabold"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/admin_note_border"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/clock" app:tint="#F97316"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="MENUNGGU VERIFIKASI" android:textColor="#F97316" android:textSize="12sp" android:fontFamily="@font/inter_extrabold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QRIS" android:textColor="#111827" android:textSize="11sp" android:fontFamily="@font/inter_bold" android:background="@drawable/admin_tab_background_parent" android:paddingHorizontal="10dp" android:paddingVertical="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bukti Pembayaran" android:fontFamily="@font/inter_bold" android:textColor="#111827" android:drawableStart="@drawable/receipttext" android:drawablePadding="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Ketuk gambar untuk melihat detail. Pastikan nominal Rp 73.000 telah masuk ke rekening Anda." android:textSize="12sp" android:textColor="#6B7280" android:fontFamily="@font/inter_regular"/>

                    <ImageView
                        android:id="@+id/ivBuktiBayar"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="centerCrop"
                        android:background="#F3F4F6"
                        app:cardCornerRadius="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/admin_note_border"
                        android:padding="16dp"
                        android:gravity="top">
                        <CheckBox
                            android:id="@+id/cbVerifikasi"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:buttonTint="#F97316"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saya telah memverifikasi pembayaran ini" android:textColor="#111827" android:textSize="13sp" android:fontFamily="@font/inter_bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Saya mengkonfirmasi bahwa jumlah dan detail pengirim sudah sesuai dengan riwayat mutasi." android:textSize="11sp" android:textColor="#6B7280" android:fontFamily="@font/inter_regular"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutFooterButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTolakDetail"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="✕ Tolak"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            android:background="@drawable/admin_btn_outline_red"
            android:fontFamily="@font/inter_bold"/>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVerifikasiTerima"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.4"
            android:layout_marginStart="8dp"
            android:text="✓ Verifikasi &amp; Terima"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:background="@drawable/admin_btn_green_rounded"
            android:fontFamily="@font/inter_bold"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>