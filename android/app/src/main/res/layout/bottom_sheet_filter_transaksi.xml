<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <View
        android:id="@+id/view_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_title_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Transaksi"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/view_handle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_desc_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cari data yang ingin kamu lihat"
        android:textSize="14sp"
        android:textColor="#757575"
        app:layout_constraintTop_toBottomOf="@id/tv_title_filter"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btn_close_filter"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/close_without_circle"
        app:tint="@color/gray_text"
        android:background="@drawable/bg_circle_outline"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/tv_title_filter"
        app:layout_constraintBottom_toBottomOf="@id/tv_title_filter"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/label_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STATUS"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_desc_filter"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_status_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/label_status">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_semua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semua"
            android:checkable="true"
            android:checked="true"
            app:chipCornerRadius="10dp"
            app:chipBackgroundColor="@color/chip_bg_state"
            app:chipStrokeColor="@color/chip_stroke_state"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/chip_text_state"
            app:chipSurfaceColor="@android:color/transparent"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_selesai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selesai"
            android:checkable="true"
            app:chipCornerRadius="10dp"
            app:chipBackgroundColor="@color/chip_bg_state"
            app:chipStrokeColor="@color/chip_stroke_state"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/chip_text_state"
            app:chipSurfaceColor="@android:color/transparent"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_dibatalkan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dibatalkan"
            android:checkable="true"
            app:chipCornerRadius="10dp"
            app:chipBackgroundColor="@color/chip_bg_state"
            app:chipStrokeColor="@color/chip_stroke_state"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/chip_text_state"
            app:chipSurfaceColor="@android:color/transparent"/>

    </com.google.android.material.chip.ChipGroup>

    <View
        android:id="@+id/divider_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F5F5F5"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cg_status_filter" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/divider_line">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_filter"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Atur Ulang"
            android:textColor="#616161"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#F5F5F5"
            app:cornerRadius="12dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply_filter"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Terapkan"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            app:backgroundTint="#00C853"
            app:iconGravity="textStart"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>