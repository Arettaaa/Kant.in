<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvMenuQty"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="2x"
            android:textColor="#F97316"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMenuNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/tvMenuQty"
            android:text="Nasi Goreng Spesial"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMenuHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Rp 30.000"
            android:textColor="#111827"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Note hanya muncul kalau ada isinya -->
    <TextView
        android:id="@+id/tvMenuNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>