<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivCustomer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/avatars" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/cardProfile"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alex Johnson"
                android:textColor="#111827"
                android:textSize="16sp"
                android:fontFamily="@font/inter_bold" />
            <TextView
                android:id="@+id/tvOrderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="2 mnt yang lalu"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="end"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#ORD-089"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/admin_badge_purple_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Ambil Sendiri"
                android:textColor="#8B5CF6"
                android:textSize="10sp"
                android:fontFamily="@font/inter_bold" />
        </LinearLayout>
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#F3F4F6" />

    <TextView
        android:id="@+id/tvMenuSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2x Nasi Goreng Spesial\n1x Brown Sugar Boba"
        android:textColor="#374151"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        android:fontFamily="@font/inter_medium" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#F3F4F6" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular" />
        <TextView
            android:id="@+id/tvTotalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Rp 68.000"
            android:textColor="#F97316"
            android:textSize="18sp"
            android:fontFamily="@font/inter_extrabold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTolak"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/admin_btn_outline_red"
            android:text="✕  Tolak"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            android:fontFamily="@font/inter_bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTerima"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.4"
            android:layout_marginStart="8dp"
            android:background="@drawable/admin_btn_green_rounded"
            android:text="✓  Terima Pesanan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/inter_bold" />
    </LinearLayout>
</LinearLayout>
</androidx.cardview.widget.CardView>