<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_outline"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/layoutBadgeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_badge_green_light"
            android:gravity="center_vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/imgBadgeIcon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/checkcircle"
                app:tint="#10B981" />

            <TextView
                android:id="@+id/tvBadgeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:textSize="10sp" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/chefhat"
            app:tint="#6B7280"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaKantin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNamaMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Bayar"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTotalBayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Tombol untuk status COMPLETED (ada Nilai + Pesan Lagi) -->
        <LinearLayout
            android:id="@+id/layoutBtnCompleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Tombol Nilai (tampil saat belum dinilai) -->
            <TextView
                android:id="@+id/btnNilai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_outline_yellow"
                android:drawablePadding="4dp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Nilai"
                android:textColor="#FBBF24"
                android:textSize="11sp"
                app:drawableStartCompat="@drawable/star"
                app:drawableTint="#FBBF24" />

            <!-- Bintang read-only (tampil saat sudah dinilai, awalnya GONE) -->
            <LinearLayout
                android:id="@+id/layoutStarDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView android:id="@+id/starView1"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/star"
                    app:tint="#FDC700" />
                <ImageView android:id="@+id/starView2"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/star"
                    android:layout_marginStart="2dp"
                    app:tint="#FDC700" />
                <ImageView android:id="@+id/starView3"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/star"
                    android:layout_marginStart="2dp"
                    app:tint="#FDC700" />
                <ImageView android:id="@+id/starView4"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/star"
                    android:layout_marginStart="2dp"
                    app:tint="#FDC700" />
                <ImageView android:id="@+id/starView5"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/star"
                    android:layout_marginStart="2dp"
                    app:tint="#FDC700" />
            </LinearLayout>
            <TextView
                android:id="@+id/btnPesanLagi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/btn_outline_orange"
                android:drawablePadding="4dp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Pesan Lagi"
                android:textColor="#F97316"
                android:textSize="11sp"
                app:drawableStartCompat="@drawable/again"
                app:drawableTint="#F97316" />
        </LinearLayout>

        <!-- Tombol untuk status CANCELLED (hanya Pesan Lagi) -->
        <TextView
            android:id="@+id/btnPesanLagiCancelled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_outline_orange"
            android:drawablePadding="4dp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="Pesan Lagi"
            android:textColor="#F97316"
            android:textSize="11sp"
            android:visibility="gone"
            app:drawableStartCompat="@drawable/again"
            app:drawableTint="#F97316" />

    </RelativeLayout>
</LinearLayout>