<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/btnKeluar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Keluar"
                android:textColor="#9CA3AF" />
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/admin_badge_status_open"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="MENERIMA PESANAN"
                android:textColor="#10B981"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <ImageView
                android:id="@+id/ivStore"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/bg_badge_orange_light" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivStore"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Warung Bu Ani"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dasbor Kantin"
                    android:textColor="#6B7280" />
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchStatusKantin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:checked="true"
                app:thumbTint="#FFFFFF"
                app:trackTint="#10B981" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Tab Navigation -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/admin_tab_background_parent"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:id="@+id/tabMasuk"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/admin_tab_indicator_active"
            android:gravity="center">
            <TextView
                android:id="@+id/tvTabMasukLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesanan Masuk"
                android:textStyle="bold"
                android:textColor="#111827" />
            <TextView
                android:id="@+id/tvTabMasukBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/admin_notif_circle_orange"
                android:gravity="center"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabProses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <TextView
                android:id="@+id/tvTabProsesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diproses"
                android:textColor="#6B7280" />
            <TextView
                android:id="@+id/tvTabProsesBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/admin_notif_circle_gray"
                android:gravity="center"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Container Fragment -->
    <FrameLayout
        android:id="@+id/containerDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs" />

    <!-- Bottom Nav -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/activity_footer_admin"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>