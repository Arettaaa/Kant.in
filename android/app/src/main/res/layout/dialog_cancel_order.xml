<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    android:fitsSystemWindows="true">


<View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginBottom="24dp"
        android:background="#E5E7EB" />

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_circle_red_outline" android:padding="16dp"
        android:src="@drawable/close"
        app:tint="#DC2626" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Batalkan Pesanan?"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Apakah Anda yakin ingin membatalkan pesanan ini? Aksi ini tidak dapat dibatalkan kembali."
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmCancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Ya, Batalkan"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#FF3B30"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackFromDialog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Kembali"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:backgroundTint="#F3F4F6"
        app:cornerRadius="12dp" />

</LinearLayout>