<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:ignore="HardcodedText"
    android:fitsSystemWindows="true">

    <LinearLayout
    android:id="@+id/header_section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white"
    android:elevation="4dp"
    >

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_keluar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/tv_status_badge"
            android:layout_marginEnd="8dp"
            app:drawableStartCompat="@drawable/chevronleft"
            android:drawablePadding="8dp" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="MENERIMA PESANAN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#00B050"
            android:background="@drawable/bg_badge_menerima_pesanan"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"/>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_shop_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF3E0">

            <ImageView
                android:id="@+id/iv_shop_icon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:contentDescription="Ikon Warung"
                android:src="@drawable/avatar" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cv_shop_icon"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/switch_kantin_status"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_shop_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Warung Bu Ani"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tv_shop_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dasbor Kantin"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/switch_kantin_status"

            android:layout_width="56dp"
            android:layout_height="32dp"

            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"

            android:button="@null"

            android:background="@drawable/selector_switch_kantin"

            android:checked="true" />
    </RelativeLayout>
</LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_section"
        android:layout_above="@+id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/tab_container"
                android:padding="4dp">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab"

                    app:tabIndicatorColor="#F97316"
                    app:tabIndicatorHeight="4dp"
                    app:tabIndicatorFullWidth="false"

                    app:tabRippleColor="@null"
                    app:tabMode="fixed"/>
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <View
            android:id="@+id/view_overlay_tutup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99F8F9FA"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>
    </FrameLayout>

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/activity_footer_admin"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true" />

</RelativeLayout>