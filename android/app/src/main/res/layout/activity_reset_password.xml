<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:fitsSystemWindows="true">


<LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_peach"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_circle_outline"
            android:elevation="2dp"
            android:padding="10dp"
            android:src="@drawable/chevronleft"
            app:tint="#1A1A1A" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_icon_orange"
                android:elevation="8dp"
                android:outlineSpotShadowColor="#FF7A00"
                android:padding="16dp"
                android:src="@drawable/clock"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textStyle="bold"
                android:text="Reset Kata Sandi"
                android:textColor="#1A1A1A"
                android:textSize="24sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="36dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Silakan masukkan kata sandi baru untuk\nemail@id"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/inter_bold"
                android:text="Kata Sandi Baru"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_rounded"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:alpha="0.5"
                    android:src="@drawable/lock" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/ivToggleNewPassword"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.5"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/eye" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/inter_bold"
                android:text="Konfirmasi Kata Sandi"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_rounded"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:alpha="0.5"
                    android:src="@drawable/lock" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/ivToggleConfirmPassword"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.5"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/eye" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/inter_bold"
                android:text="Simpan Kata Sandi  ›"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#F97316"
                app:cornerRadius="16dp"
                app:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>