<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">


<ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgCover"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="#E5E7EB"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/imgCover"
                android:layout_marginTop="-24dp"
                android:background="@drawable/bg_sheet_rounded"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvNamaWarung"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:text="Warung Bu Ani"
                        android:textColor="#1A1A1A"
                        android:textSize="22sp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#FFF7ED"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/star_on"
                                app:tint="#F97316" />

                            <TextView
                                android:id="@+id/tvRatingWarung"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textStyle="bold"
                                android:text="4.8"
                                android:textColor="#F97316"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDeskripsiWarung"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Menyediakan ayam geprek dengan berbagai level pedas dan aneka minuman segar."
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/mappin"
                        app:tint="#9CA3AF" />

                    <TextView
                        android:id="@+id/tvLokasiKantin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Kantin Utara"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="•"
                        android:textColor="#D1D5DB"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="#9CA3AF" />

                    <TextView
                        android:id="@+id/tvEstimasiWaktu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="10-15 min"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#F3F4F6" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#9CA3AF" />

                    <EditText
                        android:id="@+id/etSearchMenu"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:hint="Cari menu di warung ini..."
                        android:inputType="text"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textStyle="bold"
                    android:text="Makanan Utama"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardFood1"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgMenu1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#F3F4F6"
                                android:scaleType="centerCrop" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:layout_toEndOf="@id/cardFood1"
                            android:layout_toStartOf="@id/btnAdd1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNamaMenu1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:text="Nasi Goreng Spesial"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvDeskripsiMenu1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="Nasi goreng dengan sambal bawang asli"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvHargaMenu1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textStyle="bold"
                                android:text="Rp 25.000"
                                android:textColor="#F97316"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnAdd1"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground"
                            app:cardBackgroundColor="#FFF7ED"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="#F97316" />
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardFood2"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgMenu2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#F3F4F6"
                                android:scaleType="centerCrop" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:layout_toEndOf="@id/cardFood2"
                            android:layout_toStartOf="@id/btnAdd2"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNamaMenu2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:text="Ayam Geprek Keju"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvDeskripsiMenu2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="Ayam geprek + lelehan keju mozzarella"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvHargaMenu2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textStyle="bold"
                                android:text="Rp 18.000"
                                android:textColor="#F97316"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnAdd2"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground"
                            app:cardBackgroundColor="#FFF7ED"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="#F97316" />
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="16dp"
                    android:textStyle="bold"
                    android:text="Minuman Segar"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardDrink1"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgMenu3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#F3F4F6"
                                android:scaleType="centerCrop" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:layout_toEndOf="@id/cardDrink1"
                            android:layout_toStartOf="@id/btnAdd3"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNamaMenu3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:text="Es Teh Manis"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvDeskripsiMenu3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Teh melati asli"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvHargaMenu3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textStyle="bold"
                                android:text="Rp 4.000"
                                android:textColor="#F97316"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnAdd3"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground"
                            app:cardBackgroundColor="#FFF7ED"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="#F97316" />
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="60dp" />

            </LinearLayout>
        </RelativeLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/btnBackWarung"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_circle_outline"
        android:backgroundTint="#80FFFFFF"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:padding="10dp"
        android:src="@drawable/chevronleft"
        app:tint="#1A1A1A" />

</RelativeLayout>